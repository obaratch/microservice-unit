{
  "name": "@obalab/microservice-unit",
  "description": "a micro-webservice scaffold",
  "version": "0.0.0",
  "type": "module",
  "author": "Takashi Obara",
  "license": "MIT",
  "engines": {
    "node": ">=26",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "run-p start-backend-dev start-frontend-dev",
    "stop": "scripts/force-quit-apps.sh",
    "start": "run-p start-backend start-frontend >> log/all.log 2>&1",
    "start-frontend-dev": "vite --host",
    "build": "run-p build-backend build-frontend",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "build-frontend": "vite build --mode production",
    "start-frontend": "serve -s -n -u -l 8080 app-frontend/dist",
    "build-backend": "tsc -p tsconfig.backend.json",
    "start-backend-dev": "cross-env NODE_ENV=dev tsx watch app-backend/src/main.ts | pino-pretty -c -t SYS:'yyyy-mm-dd HH:MM:ss.l' -i hostname",
    "start-backend": "npm run build-backend && node app-backend/dist/main.js"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "modern-css-reset": "^1.4.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "sass": "^1.99.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "axios": "^1.16.1",
    "cross-env": "^10.1.0",
    "hono": "^4.12.18",
    "http-status-codes": "^2.3.0",
    "lodash": "^4.18.1",
    "npm-run-all": "^4.1.5",
    "pino": "^10.3.1",
    "sequelize": "^6.37.8",
    "serve": "^14.2.6",
    "sqlite3": "^6.0.1",
    "statman-stopwatch": "^2.18.1",
    "ws": "^8.20.1"
  }
}
